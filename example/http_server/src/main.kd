import std.http

mut app := std.http.App::new()

app.ws("/ws/echo", |req, ws| {
    loop {
        msg := ws.receive()
        match msg {
            Option::Some(msg) => {
                match msg.kind {
                    std.http.WebSocketMessageKind::Text => {
                        if !ws.send(msg) {
                            return
                        }
                    }
                    std.http.WebSocketMessageKind::Binary => {
                        if !ws.send(msg) {
                            return
                        }
                    }
                    std.http.WebSocketMessageKind::Close => {
                        return
                    }
                    std.http.WebSocketMessageKind::Ping => {},
                    std.http.WebSocketMessageKind::Pong => {},
                }
            }
            Option::None => {
                return
            }
        }
    }
})

app.get("/", |req, res| {
    res.send_text("Kaede!")
})

app.post("/echo", |req, res| {
    res.send_bytes(req.body)
})

app.get("/status/notfound", |req, res| {
    res.status(std.http.Status::NotFound).send_text("Not Found")
})

app.get("/query", |req, res| {
    name := req.query("name")
    res.send_text(match name {
        Option::Some(name) => name.as_str(),
        Option::None => "No name provided"
    })
})

app.get("/users/:id", |req, res| {
    id := req.param("id")
    res.send_text(match id {
        Option::Some(id) => id.as_str(),
        Option::None => "No id provided"
    })
})

app.listen(port=8080)
