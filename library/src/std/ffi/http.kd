pub extern "C" fn kaede_http_ws_accept(key: *i8, key_len: u64, out: *i8, out_len: u64): i32

// Wraps the native helper that computes Sec-WebSocket-Accept.
pub fn __http_ws_accept(key: [u8], out: mut [u8]): i32 {
    return kaede_http_ws_accept(key.as_ptr() as *i8, key.len(), out.as_ptr() as *i8, out.len())
}
