import std.ffi.io

use std.ffi.io.write

export fun print(msg: str) -> i32 {
    return write(1, msg)
}

export fun println(msg: str) -> i32 {
    print(msg)
    return write(1, "\n")
}

export fun eprint(msg: str) -> i32 {
    return write(2, msg)
}

export fun eprintln(msg: str) -> i32 {
    eprint(msg)
    return write(2, "\n")
}
