import std.ffi.io

use std.ffi.io.write

pub fn print(msg: str): i32 {
    return write(1, msg)
}

pub fn println(msg: str): i32 {
    print(msg)
    return write(1, "\n")
}

pub fn eprint(msg: str): i32 {
    return write(2, msg)
}

pub fn eprintln(msg: str): i32 {
    eprint(msg)
    return write(2, "\n")
}
