import std.net.http
import std.sync

use std.sync.Channel

struct Subscriber {
    events: Channel<i32>,
}

fun main() {
    mut app := std.net.http.App::new()
    app.post("/x", |req, res| {
        let sub = Subscriber { events: Channel<i32>::with_capacity(1) }
        if sub.events.try_send(1) {
            res.send("ok")
        }
    })
}
